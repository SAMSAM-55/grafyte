{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-vs",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "PYBIND11_FINDPYTHON": "ON",
        "Python_FIND_REGISTRY": "NEVER",
        "Python_FIND_STRATEGY": "LOCATION"
      }
    },

    {
      "name": "base-linux",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux/_base",
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Docker - ManyLinux"
        }
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "PYBIND11_FINDPYTHON": "ON",
        "Python_FIND_REGISTRY": "NEVER",
        "Python_FIND_STRATEGY": "LOCATION"
      }
    },


    {
      "name": "py310",
      "inherits": "base-vs",
      "binaryDir": "${sourceDir}/build/py310",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py310",
        "Python_EXECUTABLE": "$env{PYTHON_HOME}/Python310/python.exe"
      }
    },
    {
      "name": "py311",
      "inherits": "base-vs",
      "binaryDir": "${sourceDir}/build/py311",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py311",
        "Python_EXECUTABLE": "$env{PYTHON_HOME}/Python311/python.exe"
      }
    },
    {
      "name": "py312",
      "inherits": "base-vs",
      "binaryDir": "${sourceDir}/build/py312",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py312",
        "Python_EXECUTABLE": "$env{PYTHON_HOME}/Python312/python.exe"
      }
    },
    {
      "name": "py313",
      "inherits": "base-vs",
      "binaryDir": "${sourceDir}/build/py313",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py313",
        "Python_EXECUTABLE": "$env{PYTHON_HOME}/Python313/python.exe"
      }
    },
    {
      "name": "py314",
      "inherits": "base-vs",
      "binaryDir": "${sourceDir}/build/py314",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py314",
        "Python_EXECUTABLE": "$env{PYTHON_HOME}/Python314/python.exe"
      }
    },

    {
      "name": "py310-linux",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build-linux/py310",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py310",
        "Python_EXECUTABLE": "/opt/python/cp310-cp310/bin/python"
      }
    },
    {
      "name": "py311-linux",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build-linux/py311",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py311",
        "Python_EXECUTABLE": "/opt/python/cp311-cp311/bin/python"
      }
    },
    {
      "name": "py312-linux",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build-linux/py312",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py312",
        "Python_EXECUTABLE": "/opt/python/cp312-cp312/bin/python"
      }
    },
    {
      "name": "py313-linux",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build-linux/py313",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py313",
        "Python_EXECUTABLE": "/opt/python/cp313-cp313/bin/python"
      }
    },
    {
      "name": "py314-linux",
      "inherits": "base-linux",
      "binaryDir": "${sourceDir}/build-linux/py314",
      "cacheVariables": {
        "GRAFYTE_PY_TAG": "py314",
        "Python_EXECUTABLE": "/opt/python/cp314-cp314/bin/python"
      }
    }
  ],

  "buildPresets": [
    { "name": "build-py310", "configurePreset": "py310", "configuration": "Release", "targets": ["grafyte_py310"] },
    { "name": "build-py311", "configurePreset": "py311", "configuration": "Release", "targets": ["grafyte_py311"] },
    { "name": "build-py312", "configurePreset": "py312", "configuration": "Release", "targets": ["grafyte_py312"] },
    { "name": "build-py313", "configurePreset": "py313", "configuration": "Release", "targets": ["grafyte_py313"] },
    { "name": "build-py314", "configurePreset": "py314", "configuration": "Release", "targets": ["grafyte_py314"] },

    { "name": "build-py310-linux", "configurePreset": "py310-linux", "configuration": "Release", "targets": ["grafyte_py310"] },
    { "name": "build-py311-linux", "configurePreset": "py311-linux", "configuration": "Release", "targets": ["grafyte_py311"] },
    { "name": "build-py312-linux", "configurePreset": "py312-linux", "configuration": "Release", "targets": ["grafyte_py312"] },
    { "name": "build-py313-linux", "configurePreset": "py313-linux", "configuration": "Release", "targets": ["grafyte_py313"] },
    { "name": "build-py314-linux", "configurePreset": "py314-linux", "configuration": "Release", "targets": ["grafyte_py314"] }
  ]
}
